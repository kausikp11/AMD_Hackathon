# Core app. VENV_DIR is optional; scripts auto-detect active venv, ./venv,
# then ./.venv.
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860

# Leave VLM_BACKEND unset to auto-use Qwen when localhost:8000 is serving,
# otherwise fallback to heuristic. Set explicitly if you want to force a mode.
# VLM_BACKEND=heuristic
# VLM_BACKEND=qwen
LOCATOR_BACKEND=labels

# Qwen VLM, served through ROCm-compatible vLLM on AMD MI300.
# Enable with:
#   VLM_BACKEND=qwen
#   QWEN_VLM_BASE_URL=http://localhost:8000/v1
QWEN_VLM_BASE_URL=http://localhost:8000/v1
QWEN_VLM_API_KEY=EMPTY
QWEN_VLM_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
QWEN_VLLM_PORT=8000
QWEN_VLLM_MAX_MODEL_LEN=8192
QWEN_VLLM_GPU_MEMORY_UTILIZATION=0.85
QWEN_VLLM_MAX_NUM_SEQS=8

# NVIDIA LocateAnything optional/experimental on AMD.
# For final AMD-only demo, keep LOCATOR_BACKEND=labels unless validated.
# If serving LocateAnything through an OpenAI-compatible endpoint:
#   LOCATOR_BACKEND=nvidia_vllm
#   NVIDIA_LOCATE_ANYTHING_BASE_URL=http://localhost:8001/v1
NVIDIA_LOCATE_ANYTHING_BASE_URL=http://localhost:8001/v1
NVIDIA_LOCATE_ANYTHING_API_KEY=EMPTY
NVIDIA_LOCATE_ANYTHING_MODEL=nvidia/LocateAnything-3B
NVIDIA_LOCATE_ANYTHING_GENERATION_MODE=hybrid
NVIDIA_LOCATE_ANYTHING_MAX_TOKENS=2048
NVIDIA_LOCATE_ANYTHING_TEMPERATURE=0.7
NVIDIA_LOCATE_ANYTHING_ATTN_IMPLEMENTATION=sdpa
